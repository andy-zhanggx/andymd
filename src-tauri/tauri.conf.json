{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AndyMD",
  "version": "0.1.3",
  "identifier": "com.andyz.andymd",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "AndyMD",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "decorations": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "mdown", "mkd"],
        "name": "Markdown Document",
        "description": "Markdown document",
        "role": "Editor",
        "mimeType": "text/markdown"
      }
    ],
    "targets": ["app", "dmg"],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "signingIdentity": "-"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVGNzc3M0IwRUI5RjlCRkIKUldUN201L3JzSE4zNzl3SHdXeDV2dEhGc05QSFMzRGdBSDAyKzBtQ3B2WXNST3FFNHdXc3UwYjUK",
      "endpoints": [
        "https://github.com/andy-zhanggx/andymd/releases/latest/download/latest.json"
      ]
    }
  }
}
